# CCTV Vulnerability Assessment Tool - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
APP_ENV=development

# Debug mode (never True in production)
DEBUG=False

# Server configuration
APP_HOST=0.0.0.0
APP_PORT=5000

# ============================================================================
# SECURITY KEYS - GENERATE UNIQUE VALUES
# ============================================================================

# Flask secret key (for sessions, CSRF protection)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-random-secret-key-min-32-characters

# JWT secret key (for token signing)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-random-jwt-key-min-32-characters

# Encryption key (for sensitive data at rest)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-random-encryption-key

# Audit log integrity key
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUDIT_LOG_KEY=change-me-to-random-audit-key-min-32-characters

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (development only)
DATABASE_URL=sqlite:///./vapt_tool.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://username:password@localhost:5432/vapt_db

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================================
# REDIS/CELERY CONFIGURATION
# ============================================================================

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Celery broker (same as Redis)
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ============================================================================
# EMAIL CONFIGURATION (OPTIONAL - for notifications)
# ============================================================================

# SMTP server
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@vapt-tool.local

# ============================================================================
# AWS/S3 CONFIGURATION (OPTIONAL - for report backup)
# ============================================================================

# Enable S3 backup
ENABLE_CLOUD_BACKUP=False

# S3 bucket
S3_BUCKET=vapt-reports-backup

# S3 region
S3_REGION=us-east-1

# AWS credentials
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ============================================================================
# SCANNING CONFIGURATION
# ============================================================================

# Maximum concurrent scans per tenant
MAX_CONCURRENT_SCANS=3

# Maximum host count in single scan
MAX_SCAN_HOSTS=1000

# Overall scan timeout in seconds (1 hour)
SCAN_TIMEOUT_SECONDS=3600

# Port scanning timeout in seconds
PORT_SCAN_TIMEOUT=10

# Network scanning timeout in seconds
NETWORK_SCAN_TIMEOUT=30

# Enable deep vulnerability scanning (slower)
ENABLE_DEEP_SCAN=False

# Enable credential testing (requires caution)
ENABLE_CREDENTIAL_TESTING=False

# ============================================================================
# REPORT CONFIGURATION
# ============================================================================

# Report storage location
REPORTS_DIR=./backend/reports

# Supported formats
REPORT_FORMATS=json,html,pdf

# Report retention in days
REPORT_RETENTION_DAYS=90

# Maximum report size in MB
MAX_REPORT_SIZE_MB=100

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins (comma-separated)
# For development: http://localhost:3000,http://localhost:5000
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log directory
LOGS_DIR=./backend/logs

# ============================================================================
# SESSION CONFIGURATION
# ============================================================================

# Session cookie security
SESSION_COOKIE_SECURE=False  # True in production
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Session lifetime in hours
SESSION_LIFETIME_HOURS=24

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable experimental features
EXPERIMENTAL_FEATURES=False

# ============================================================================
# ADMIN USER (INITIAL SETUP ONLY)
# ============================================================================

# Initial admin credentials (change after first login)
# ADMIN_USER=admin
# ADMIN_PASS=SecurePassword123!

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Slack webhook for notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# JIRA integration (optional)
# JIRA_URL=https://your-jira.atlassian.net
# JIRA_USER=your-email@example.com
# JIRA_TOKEN=your-api-token
